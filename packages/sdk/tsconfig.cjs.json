{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "rootDir": "src",
    "outDir": "./dist/cjs",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
